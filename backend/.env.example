PORT=3001
NODE_ENV=development
DB_HOST=localhost
DB_PORT=3306
DB_NAME=campus_club_system
DB_USER=root
DB_PASSWORD=your_password
DB_NAME_TEST=campus_club_system_test
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=24h
DEFAULT_ADMIN_EMAIL=admin@ccms.local
DEFAULT_ADMIN_USERNAME=system_admin
DEFAULT_ADMIN_STUDENT_ID=00000000000
DEFAULT_ADMIN_PASSWORD=Admin@123456

# MariaDB 兼容说明：
# 1) 保持 dialect=mysql（Sequelize 对 MariaDB 使用 mysql 协议）
# 2) DB_HOST/DB_PORT/DB_USER/DB_PASSWORD 配置成你的 MariaDB 实例即可
