{
  "name": "campus-club-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w backend & npm run start -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run start -w frontend",
    "start": "npm run start -w backend",
    "db:check": "npm run db:check -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:migrate:status": "npm run db:migrate:status -w backend",
    "db:migrate:undo": "npm run db:migrate:undo -w backend",
    "build": "npm run build -w frontend",
    "test": "CI=true npm run test -ws --if-present -- --watch=false",
    "lint": "npm run lint --workspaces --if-present",
    "lint:backend": "npm run lint -w backend",
    "lint:frontend": "npm run lint -w frontend",
    "lint:fix": "npm run lint --workspaces --if-present -- --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.8.1"
  }
}
